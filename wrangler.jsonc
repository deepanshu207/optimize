{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "optimize",
  "main": "worker.mjs",
  "workers_dev": true,
  "compatibility_date": "2026-07-22",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./app.suppliersden.com",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "compatibility_flags": ["nodejs_compat"]
}
